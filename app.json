{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "scheme": "fiestaa",
    "splash": {
      "image": "./assets/fiestaa-logo.png",
      "backgroundColor": "#ffffff",
      "resizeMode": "contain"
    },
    "ios": {
      "splash": {
        "image": "./assets/fiestaa-logo.png",
        "backgroundColor": "#ffffff",
        "resizeMode": "contain"
      }
    },
    "android": {
      "package": "com.anonymous.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "splash": {
        "image": "./assets/fiestaa-logo.png",
        "backgroundColor": "#ffffff",
        "resizeMode": "contain"
      },
      "softwareKeyboardLayoutMode": "pan",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "fiestaa",
              "host": "auth",
              "pathPrefix": "/callback"
            },
            {
              "scheme": "fiestaa"
            }
          ],
          "category": [
            "DEFAULT",
            "BROWSABLE"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "dangerous": {
        "disableCoop": true
      }
    },
    "extra": {
      "auth": {
        "googleClientId": "601001909197-a7i7qjqvd5aimtojh9lub8vvafer2v0u.apps.googleusercontent.com"
      },
      "eas": {
        "projectId": "d9ecc209-609f-4f51-a8e7-9b100300d100"
      }
    }
  }
}
